    {
      "parameters": {
        "jsCode": "const input = $('Parse Input').first().json;\nconst style = $('Extract Rewritten Style').first().json.style_rewritten;\n\nconst infoText = `CoverSwap Simulation Report\n============================\nDate: ${new Date().toISOString()}\n\nClient:\n  Nom: ${input.name}\n  Téléphone: ${input.phone}\n  Email: ${input.email}\n\nRéférences Cover Styl':\n  Crédence: ${input.credence_ref} - ${input.credence_name} (${input.credence_famille})\n  Plan de travail: ${input.plan_ref} - ${input.plan_name} (${input.plan_famille})\n  Façade: ${input.facade_ref} - ${input.facade_name} (${input.facade_famille})\n\nMessage client: ${input.message}\n\nStyle réécrit par IA:\n${style}\n`;\n\nreturn [{\n  json: { infoText },\n  binary: {\n    info: {\n      data: Buffer.from(infoText).toString('base64'),\n      mimeType: 'text/plain',\n      fileName: 'simulation_info.txt'\n    }\n  }\n}];"
      },
