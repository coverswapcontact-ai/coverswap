# ──────────────────────────────────────────────────────────────────
# CoverSwap — Variables d'environnement requises
# Copier ce fichier en .env.local et remplir les valeurs.
# ──────────────────────────────────────────────────────────────────

# OpenAI API — simulation IA (OBLIGATOIRE en production)
OPENAI_API_KEY=""

# CRM Webhook (OBLIGATOIRE en production — ne PAS laisser localhost)
CRM_WEBHOOK_URL=""
CRM_WEBHOOK_SECRET=""

# URL publique du site (utilisée pour metadata OG, canonical, etc.)
NEXT_PUBLIC_SITE_URL="https://coverswap.fr"

# ──────────────────────────────────────────────────────────────────
# ANALYTICS — laisser vide = tracker désactivé
# ──────────────────────────────────────────────────────────────────

# Google Analytics 4 — format : G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=""

# Meta (Facebook) Pixel — format : 15-16 chiffres
NEXT_PUBLIC_META_PIXEL_ID=""

# Microsoft Clarity — format : 10 caractères alphanumériques
NEXT_PUBLIC_CLARITY_ID=""

# ──────────────────────────────────────────────────────────────────
# RATE LIMITING (optionnel, valeurs par défaut si absent)
# ──────────────────────────────────────────────────────────────────

# SIMULATION_DAILY_LIMIT_PER_IP=5
# SIMULATION_DAILY_LIMIT_GLOBAL=80
